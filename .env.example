REPORT_API_PORT=4021
MCP_SERVER_PORT=3001
WEB_PORT=5173
REPORT_API_URL=http://localhost:4021
AGENT_PAY_RESOURCE_BASE_URL=http://127.0.0.1:4021
# Canonical public origin used when serving /skill.md and the MCP skill resource.
# Set in production to prevent Host/X-Forwarded-Proto poisoning in generated examples.
AGENT_PAY_PUBLIC_ORIGIN=http://127.0.0.1:4021
CASPER_NETWORK=casper-testnet
CASPER_RPC_URL=https://node.testnet.casper.network/rpc
CASPER_NODE_ADDRESS=https://node.testnet.casper.network/rpc
CASPER_CHAIN_NAME=casper-test
CSPR_TRADE_MCP_URL=https://mcp.cspr.trade/mcp
AGENT_PAY_REPO_ROOT=.
AGENT_PAY_REGISTRY_PACKAGE_HASH=
AGENT_PAY_REGISTRY_CONTRACT_HASH=
AGENT_PAY_REGISTRY_RECORDER_ACCOUNT_HASH=
AGENT_PAY_REGISTRY_RECORDER_KEY_PATH=
AGENT_PAY_RECORD_SCRIPT=contracts/agent-pay-registry/scripts/record-decision-testnet.sh
AGENT_PAY_RECEIPT_RECORD_SCRIPT=contracts/agent-pay-registry/scripts/record-receipt-testnet.sh
CASPER_CLIENT_COMMAND=casper-client
CASPER_SECRET_KEY_PATH=
CASPER_PUBLIC_KEY_PATH=
# Use this instead of CASPER_PUBLIC_KEY_PATH when a wallet gives you an account hash/address.
CASPER_ACCOUNT_IDENTIFIER=
AGENT_PAY_CONTRACT_TOOLCHAIN=nightly-2025-06-23
AGENT_PAY_INSTALL_PAYMENT_AMOUNT=150000000000
AGENT_PAY_RECORD_PAYMENT_AMOUNT=5000000000
AGENT_PAY_RECEIPT_RECORD_PAYMENT_AMOUNT=5000000000
CASPER_CONFIRMATION_ATTEMPTS=5
CASPER_CONFIRMATION_DELAY_MS=1500
AGENT_PAY_REGISTRY_INSTALL_HASH=
AGENT_PAY_RECEIPT_ANCHOR_HASH=
AGENT_PAY_SETTLEMENT_TX_HASH=
AGENT_PAY_DECISION_TX_HASH=
# Optional run metadata printed by npm run submission:proof when captured.
AGENT_PAY_QUOTE_ID=
AGENT_PAY_DATASET_ROOT=
SUBMISSION_GITHUB_URL=
SUBMISSION_DEMO_VIDEO_URL=
AGENT_PAY_REPORT_AMOUNT=10000
AGENT_PAY_REPORT_ASSET=CSPR
AGENT_PAY_QUOTE_TTL_SECONDS=300
# Optional buyer-side spend guards. Unset values skip that check.
AGENT_PAY_EXPECTED_PAYEE_ADDRESS=
AGENT_PAY_EXPECTED_X402_ASSET=
AGENT_PAY_EXPECTED_NETWORK=
AGENT_PAY_MAX_REPORT_AMOUNT=
X402_NETWORK=casper:casper-test
X402_FACILITATOR_URL=https://x402-facilitator.cspr.cloud
X402_FACILITATOR_AUTH_TOKEN=
CSPR_CLOUD_ACCESS_TOKEN=
# Landing token-discovery list (GET /tokens) reads CSPR.cloud with the token above.
# Defaults below point at MAINNET (real, recognizable tokens) — read-only, independent
# of the testnet x402 flow. Override for testnet if desired. Get a key: console.cspr.build
CSPR_CLOUD_BASE_URL=https://api.cspr.cloud
CSPR_CLOUD_NODE_RPC_URL=https://node.cspr.cloud/rpc
X402_ASSET_PACKAGE_HASH=
X402_TOKEN_NAME=Cep18x402
X402_TOKEN_VERSION=1
X402_TOKEN_DECIMALS=2
X402_TOKEN_SYMBOL=CSPR
X402_MAX_TIMEOUT_SECONDS=300
# Casper account hash that receives x402 payment: 00<64 hex chars>
PAYEE_ADDRESS=
