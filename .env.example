# Local-development defaults only: loopback hosts and ports are intentional here.
# Production values live in deploy/agentpay/agentpay.env.example.
REPORT_API_PORT=4021
REPORT_API_HOST=127.0.0.1
# Loopback probes are disabled unless this explicit development override is set.
AGENTPAY_ALLOW_LOOPBACK_PROBES=0
AGENTPAY_DATABASE_PATH=data/agentpay.sqlite
AGENTPAY_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
# Cookie path for operator sessions. Use /api/v1 when nginx exposes the API under /api.
AGENTPAY_SESSION_COOKIE_PATH=/v1
MCP_SERVER_PORT=3001
MCP_SERVER_HOST=127.0.0.1
# Loopback-bound bridges allow the local console automatically. This is the explicit override.
MCP_ALLOW_UNAUTHENTICATED_PRIVILEGED_TOOLS=0
# Protects mutation and raw report tools. Readiness status stays public, and the two
# funded assessment tools may use the origin-restricted public mode below.
MCP_SERVER_AUTH_TOKEN=
# Public UI assessments are opt-in, Testnet-only, origin restricted, and budget limited.
MCP_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
MCP_PUBLIC_TESTNET_ASSESSMENTS=1
MCP_PUBLIC_ASSESSMENT_WINDOW_MS=60000
MCP_PUBLIC_ASSESSMENT_RATE_LIMIT=3
MCP_PUBLIC_ASSESSMENT_DAILY_LIMIT=100
MCP_RATE_LIMIT_MAX_CLIENTS=10000
# Per-call backend URL changes are disabled unless enabled and exact-base allowlisted.
AGENT_PAY_ALLOW_REPORT_API_URL_OVERRIDE=0
AGENT_PAY_ALLOWED_REPORT_API_URLS=
WEB_PORT=5173
VITE_REPORT_API_URL=http://127.0.0.1:4021
VITE_MCP_SERVER_URL=http://127.0.0.1:3001
# Optional public HTTPS x402 service used by the auditor's one-click WCSPR check.
VITE_AGENTPAY_SERVICE_URL=https://agentpay.timidan.xyz/api
REPORT_API_URL=http://127.0.0.1:4021
AGENT_PAY_RESOURCE_BASE_URL=http://127.0.0.1:4021
# Canonical site origin used for auth challenges and browser-origin checks.
# Keep this origin-only; AGENT_PAY_RESOURCE_BASE_URL carries any /api prefix.
AGENTPAY_PUBLIC_ORIGIN=http://127.0.0.1:5173
CASPER_NETWORK=casper-testnet
CASPER_RPC_URL=https://node.testnet.casper.network/rpc
CASPER_NODE_ADDRESS=https://node.testnet.casper.network/rpc
CASPER_CHAIN_NAME=casper-test
# Evidence can be read from either Casper network while payment and registry writes stay on Testnet.
AGENTPAY_DEFAULT_EVIDENCE_NETWORK=casper-testnet
AGENTPAY_MAINNET_RPC_URL=https://node.mainnet.casper.network/rpc
AGENTPAY_TESTNET_RPC_URL=https://node.testnet.casper.network/rpc
CSPR_TRADE_MCP_URL=https://mcp.cspr.trade/mcp
# Public Mainnet CSPR.name resolver used by account checks.
CSPR_NAME_API_BASE_URL=https://api.cspr.name
AGENT_PAY_REPO_ROOT=.
AGENT_PAY_REGISTRY_PACKAGE_HASH=
AGENT_PAY_REGISTRY_CONTRACT_HASH=
AGENT_PAY_REGISTRY_RECORDER_ACCOUNT_HASH=
AGENT_PAY_REGISTRY_RECORDER_KEY_PATH=
AGENT_PAY_RECORD_SCRIPT=contracts/agent-pay-registry/scripts/record-decision-testnet.sh
AGENT_PAY_RECEIPT_RECORD_SCRIPT=contracts/agent-pay-registry/scripts/record-receipt-testnet.sh
CASPER_CLIENT_COMMAND=casper-client
CASPER_SECRET_KEY_PATH=
CASPER_PUBLIC_KEY_PATH=
# Use this instead of CASPER_PUBLIC_KEY_PATH when a client gives you an account hash/address.
CASPER_ACCOUNT_IDENTIFIER=
AGENT_PAY_CONTRACT_TOOLCHAIN=nightly-2025-06-23
AGENT_PAY_INSTALL_PAYMENT_AMOUNT=150000000000
AGENT_PAY_RECORD_PAYMENT_AMOUNT=5000000000
AGENT_PAY_RECEIPT_RECORD_PAYMENT_AMOUNT=5000000000
CASPER_CONFIRMATION_ATTEMPTS=5
CASPER_CONFIRMATION_DELAY_MS=1500
# Submission-evidence values (registry install hash, settlement/decision hashes,
# demo URLs) live in .env.submission.local, read by the submission:* scripts.
# Price in the CEP-18 token's smallest units. The API derives the readable amount
# from X402_TOKEN_DECIMALS and always exposes both values.
AGENT_PAY_REPORT_AMOUNT=10000
AGENT_PAY_QUOTE_TTL_SECONDS=300
# Public-endpoint abuse controls. Invalid values fall back to these secure defaults.
AGENT_PAY_RATE_LIMIT_WINDOW_MS=60000
AGENT_PAY_QUOTE_RATE_LIMIT=30
AGENT_PAY_AUTH_RATE_LIMIT=120
AGENT_PAY_PUBLIC_WRITE_RATE_LIMIT=120
AGENT_PAY_DISCOVERY_RATE_LIMIT=60
AGENT_PAY_RATE_LIMIT_MAX_CLIENTS=10000
AGENT_PAY_MAX_ACTIVE_QUOTES=1000
AGENT_PAY_MAX_VERDICT_CARDS=1000
AGENT_PAY_MAX_FEED_ENTRIES=500
# Buyer-side spend guards. All four are required when funded public UI checks are enabled.
AGENT_PAY_EXPECTED_PAYEE_ADDRESS=
AGENT_PAY_EXPECTED_X402_ASSET=
AGENT_PAY_EXPECTED_NETWORK=
AGENT_PAY_MAX_REPORT_AMOUNT=
X402_NETWORK=casper:casper-test
# Hosted CSPR.cloud is a proven Testnet path. It requires CSPR_CLOUD_ACCESS_TOKEN
# or X402_FACILITATOR_AUTH_TOKEN. For the self-hosted alternative, see
# docs/x402-self-hosted.md and use http://127.0.0.1:4022.
X402_FACILITATOR_URL=https://x402-facilitator.cspr.cloud
X402_FACILITATOR_AUTH_TOKEN=
# Public indexed evidence for subject checks. Defaults use the APIs behind CSPR.live;
# Casper RPC independently supplies contract state and total supply.
CSPR_LIVE_MAINNET_API_URL=https://api.mainnet.cspr.live
CSPR_LIVE_TESTNET_API_URL=https://api.testnet.cspr.live
# Optional. The landing token-discovery list (GET /tokens) reads CSPR.cloud.
# Prefer X402_FACILITATOR_AUTH_TOKEN for facilitator auth so these concerns stay
# independent. Subject checks use public CSPR.live unless the separate subject
# credential below is intentionally configured.
CSPR_CLOUD_ACCESS_TOKEN=
CSPR_CLOUD_SUBJECT_ACCESS_TOKEN=
# CSPR.cloud discovery endpoints.
# Defaults below point at MAINNET (real, recognizable tokens) — read-only, independent
# of the testnet x402 flow. Override for testnet if desired. Get a key: console.cspr.build
CSPR_CLOUD_BASE_URL=https://api.cspr.cloud
CSPR_CLOUD_NODE_RPC_URL=https://node.cspr.cloud/rpc
# Testnet evidence endpoints. Mainnet checks use CSPR_CLOUD_BASE_URL and
# CSPR_CLOUD_NODE_RPC_URL above.
CSPR_CLOUD_SUBJECT_BASE_URL=https://api.testnet.cspr.cloud
CSPR_CLOUD_SUBJECT_NODE_RPC_URL=https://node.testnet.cspr.cloud/rpc
X402_ASSET_PACKAGE_HASH=3d80df21ba4ee4d66a2a1f60c32570dd5685e4b279f6538162a5fd1314847c1e
X402_TOKEN_NAME="Wrapped CSPR"
X402_TOKEN_VERSION=1
X402_TOKEN_DECIMALS=9
X402_TOKEN_SYMBOL=WCSPR
X402_MAX_TIMEOUT_SECONDS=300
# Casper account hash that receives x402 payment: 00<64 hex chars>
PAYEE_ADDRESS=
