{
  "name": "@agent-pay/mcp-server",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx src/server.ts",
    "start": "node --conditions=production dist/server.js",
    "stdio": "node --conditions=production dist/stdio.js",
    "stdio:dev": "tsx src/stdio.ts",
    "test": "vitest run",
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@agent-pay/client": "workspace:*",
    "@agent-pay/core": "workspace:*",
    "@agent-pay/report-api": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^5.2.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "supertest": "^7.1.4",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
